{
  "name": "ajnas-runtime",
  "version": "0.2.1",
  "description": "Policy-gated agent workflow runtime with provenance receipts and human approval checkpoints.",
  "type": "module",
  "license": "MIT",
  "author": "Ajnas NB",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AjnasNB/productloop-os.git",
    "directory": "ajnas-runtime"
  },
  "homepage": "https://github.com/AjnasNB/productloop-os/tree/main/ajnas-runtime#readme",
  "bugs": {
    "url": "https://github.com/AjnasNB/productloop-os/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agents",
    "agent-runtime",
    "policy",
    "provenance",
    "human-in-the-loop",
    "workflow"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "docs",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "example:basic": "node examples/basic-runtime.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack:dry": "npm pack --dry-run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run test && npm run typecheck"
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0 || ^26.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
