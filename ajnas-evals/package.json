{
  "name": "ajnas-evals",
  "version": "0.1.2",
  "description": "Deterministic eval suites, enterprise agent-run assertions, and audit receipts for Ajnas infrastructure.",
  "type": "module",
  "license": "MIT",
  "author": "Ajnas NB",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AjnasNB/productloop-os.git",
    "directory": "ajnas-evals"
  },
  "homepage": "https://github.com/AjnasNB/productloop-os/tree/main/ajnas-evals#readme",
  "bugs": {
    "url": "https://github.com/AjnasNB/productloop-os/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agents",
    "evals",
    "testing",
    "governance",
    "audit",
    "provenance",
    "approval",
    "compliance"
  ],
  "bin": {
    "ajnas-evals": "./bin/ajnas-evals.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "docs",
    "examples",
    "fixtures"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "example:basic": "node examples/basic-eval.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack:dry": "npm pack --dry-run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run test && npm run typecheck"
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0 || ^26.0.0"
  },
  "peerDependencies": {
    "ajnas-policy": "^0.1.2",
    "ajnas-provenance": "^0.1.3",
    "ajnas-runtime": "^0.2.1"
  },
  "peerDependenciesMeta": {
    "ajnas-runtime": {
      "optional": true
    },
    "ajnas-policy": {
      "optional": true
    },
    "ajnas-provenance": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
